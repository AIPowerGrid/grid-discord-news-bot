# ── Required ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
NEWS_CHANNEL_ID=your_discord_channel_id_here
GRID_API_KEY=your_grid_api_key_here

# ── Grid /v1 (OpenAI-compatible) ──────────────────────────────────────────
# The new grid endpoint. Auth is Bearer GRID_API_KEY.
GRID_API_BASE=https://api.aipowergrid.io/v1
TEXT_MODEL=qwen3-27b
IMAGE_MODEL=z-image-turbo

# ── Behavior ───────────────────────────────────────────────────────────────
# How often to look for a new article to post (minutes).
UPDATE_FREQUENCY=60
# How many recent feed items to consider per run.
MAX_CANDIDATES=12
# debug | info | warn | error
LOG_LEVEL=info
# Where the seen/articles SQLite db lives (dedup + Q&A context survive restarts).
DB_PATH=newsbot.db

# ── Feeds (comma-separated "name|url"). Curated to AI / open-source / compute /
# crypto — generic world news is intentionally excluded. Leave unset to use the
# built-in defaults in index.js. ─────────────────────────────────────────────
# NEWS_FEEDS="Hugging Face|https://huggingface.co/blog/feed.xml,r/LocalLLaMA|https://www.reddit.com/r/LocalLLaMA/.rss"
